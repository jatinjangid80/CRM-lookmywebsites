PORT=5000

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/crm_lookmywebsites?retryWrites=true&w=majority

# JWT secrets — use long random strings (e.g. openssl rand -hex 64)
JWT_SECRET=replace_with_a_very_long_random_secret_string
JWT_REFRESH_SECRET=replace_with_another_very_long_random_secret_string

# Token expiry
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Frontend URL (for CORS)
CLIENT_URL=https://crm-lookmywebsites.vercel.app

# Environment
NODE_ENV=production
